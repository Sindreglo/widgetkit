{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@widgetkit/scheduler-vue": ["../../packages/scheduler-vue/src/index.ts"],
      "@widgetkit/scheduler": ["../../packages/scheduler/src/index.ts"],
      "@widgetkit/core": ["../../packages/core/src/index.ts"],
      "@widgetkit/booking-vue": ["../../packages/booking-vue/src/index.ts"],
      "@widgetkit/booking": ["../../packages/booking/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
